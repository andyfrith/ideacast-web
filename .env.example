# =============================================================================
# Ideacast — environment template (Phase 0)
# Copy to .env.local and fill in values. V1 scope: LinkedIn + X (Twitter) for
# OAuth and previews; post statuses draft | pending | published; image upload
# in early releases (video later).
# =============================================================================

# Public site URL (used for OAuth callbacks in later phases)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk (https://dashboard.clerk.com) — required for Phase 1 auth ---------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: custom paths (defaults match app routes /sign-in, /sign-up)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Neon + Drizzle — Phase 2 ------------------------------------------------
# Required for `bun run db:migrate` / db:push / db:studio (drizzle.config loads .env then .env.local).
# DATABASE_URL=postgresql://user:password@ep-....neon.tech/neondb?sslmode=require

# --- LLM formatting (Phase 3) -------------------------------------------------
# Required: which backend to use for POST /api/format
#   gemini = Google Gemini (Google AI Studio / Vertex-style API key)
#   ollama = Local Ollama HTTP API (dev machine or reachable host)
LLM_PROVIDER=gemini

# --- Google Gemini (when LLM_PROVIDER=gemini) --------------------------------
# Create a key in Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternative env name supported by some setups:
# GOOGLE_GENERATIVE_AI_API_KEY=
# Optional model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (when LLM_PROVIDER=ollama) ---------------------------------------
# Default base is http://127.0.0.1:11434 — only works from the same machine as Ollama
# (Vercel/serverless cannot reach your laptop; use Gemini in cloud or expose Ollama via a tunnel/public URL).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional model (default: llama3.2). For optional images, use a vision model e.g. llava.
# OLLAMA_MODEL=llama3.2

# --- OAuth (LinkedIn, X) — Phase 6 --------------------------------------------
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# --- Stripe — Phase 8 (billing scope TBD) ------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
